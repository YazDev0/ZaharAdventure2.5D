{
  "pages": [
    {
      "pageId": "General Dialogues",
      "aboutPage": "Common phrases and expressions used in dialogue scenes.",
      "pageFiles": [
        {
          "key": "greeting_hello",
          "originalValue": "Hello there, this is a (UI) test with [{0}] arguments and [{1}] awesome stuff!",
          "variants": [
            {
              "language": "en",
              "_value": "Hello there, this is a (UI) test with [{0}] arguments and [{1}] awesome stuff!"
            },
            {
              "language": "jp",
              "_value": "\u3053\u3093\u306B\u3061\u306F\u3001\u3053\u308C\u306F[{0}]\u500B\u306E\u5F15\u6570\u3068[{1}]\u500B\u306E\u7D20\u6674\u3089\u3057\u3044\u3082\u306E\u3092\u6301\u3064(UI)\u30C6\u30B9\u30C8\u3067\u3059\uFF01"
            },
            {
              "language": "ar",
              "_value": "\u0645\u0631\u062D\u0628\u064B\u0627\u060C \u0647\u0630\u0627 \u0627\u062E\u062A\u0628\u0627\u0631 (\u0648\u0627\u062C\u0647\u0629 \u0627\u0644\u0645\u0633\u062A\u062E\u062F\u0645) \u0628\u0640 [{0}] \u0648\u0633\u064A\u0637\u0627\u062A \u0648 [{1}] \u0623\u0634\u064A\u0627\u0621 \u0631\u0627\u0626\u0639\u0629!"
            }
          ],
          "aliases": [
            "Hello there with arguments"
          ]
        },
        {
          "key": "farewell_goodbye",
          "originalValue": "Goodbye and take care.",
          "variants": [
            {
              "language": "en",
              "_value": "Goodbye and take care."
            },
            {
              "language": "jp",
              "_value": "\u3055\u3088\u3046\u306A\u3089\u3001\u304A\u5143\u6C17\u3067\u3002"
            },
            {
              "language": "ar",
              "_value": "\u0648\u062F\u0627\u0639\u0627\u064B \u0648\u0627\u0639\u062A\u0646\u0650 \u0628\u0646\u0641\u0633\u0643."
            }
          ],
          "aliases": []
        },
        {
          "key": "thank_you",
          "originalValue": "Thank you for your help!",
          "variants": [
            {
              "language": "en",
              "_value": "Thank you for your help!"
            },
            {
              "language": "jp",
              "_value": "\u624B\u4F1D\u3063\u3066\u304F\u308C\u3066\u3042\u308A\u304C\u3068\u3046\uFF01"
            },
            {
              "language": "ar",
              "_value": "\u0634\u0643\u0631\u0627\u064B \u0644\u0645\u0633\u0627\u0639\u062F\u062A\u0643!"
            }
          ],
          "aliases": []
        },
        {
          "key": "arg1_test",
          "originalValue": "Some Money: 5000",
          "variants": [
            {
              "language": "en",
              "_value": "Some Money: 5000"
            },
            {
              "language": "jp",
              "_value": "\u304A\u91D1: 5000"
            },
