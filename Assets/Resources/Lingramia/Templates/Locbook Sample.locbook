              "language": "en",
              "_value": "Little Money: 50.00 Riyals"
            },
            {
              "language": "jp",
              "_value": "\u5C11\u984D: 50.00\u30EA\u30E4\u30EB"
            },
            {
              "language": "ar",
              "_value": "\u0645\u0628\u0644\u063A \u0628\u0633\u064A\u0637: 50,00 \u0631\u064A\u0627\u0644\u064B\u0627"
            }
